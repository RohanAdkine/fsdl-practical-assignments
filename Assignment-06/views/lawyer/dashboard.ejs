<%- include('../layout/header') %>

<div class="container">
    <div style="margin-bottom: 2rem;">
        <h1 style="color: var(--primary);">Lawyer Dashboard</h1>
        <p style="color: var(--text-muted);">Welcome back, Dr. <%= lawyer.name %></p>
    </div>

    <div class="grid grid-cols-2" style="margin-bottom: 3rem;">
        <div class="card">
            <h3 class="card-header">Pending Requests</h3>
            <p style="font-size: 2rem; font-weight: 700; color: var(--accent);">
                <%= appointments.filter(a => a.status === 'pending').length %>
            </p>
        </div>
        <div class="card">
            <h3 class="card-header">Accepted Appointments</h3>
            <p style="font-size: 2rem; font-weight: 700; color: var(--secondary);">
                <%= appointments.filter(a => a.status === 'accepted').length %>
            </p>
        </div>
    </div>

    <div class="card">
        <h2 class="card-header">Appointment Requests</h2>
        <% if (appointments.length === 0) { %>
            <p style="color: var(--text-muted); padding: 1rem 0;">You have no appointment requests at the moment.</p>
        <% } else { %>
            <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>Patient (User)</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% appointments.forEach(apt => { %>
                            <tr>
                                <td><strong><%= apt.userId ? apt.userId.name : 'Unknown' %></strong></td>
                                <td><%= apt.date %> at <%= apt.time %></td>
                                <td>
                                    <span class="badge badge-<%= apt.status %>" style="text-transform: capitalize;">
                                        <%= apt.status %>
                                    </span>
                                </td>
                                <td>
                                    <% if (apt.status === 'pending') { %>
                                        <div style="display: flex; gap: 0.5rem;">
                                            <form action="/lawyer/appointment/<%= apt._id %>" method="POST">
                                                <input type="hidden" name="status" value="accepted">
                                                <button type="submit" class="btn btn-success" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">Accept</button>
                                            </form>
                                            <form action="/lawyer/appointment/<%= apt._id %>" method="POST">
                                                <input type="hidden" name="status" value="rejected">
                                                <button type="submit" class="btn btn-danger" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">Reject</button>
                                            </form>
                                        </div>
                                    <% } else { %>
                                        <span style="color: var(--text-muted); font-size: 0.85rem;">No further actions</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<%- include('../layout/footer') %>
