<%- include('layout/header') %>

<div class="hero">
    <h1>Expert Legal Help, Just a Click Away</h1>
    <p>Find specialized lawyers directly online. Fast, secure, and fully verified professional consultations to solve your legal challenges.</p>
    <div style="margin-top: 2rem;">
        <% if (!user && !lawyer && !admin) { %>
            <a href="/auth/register" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.75rem 2rem;">Get Started</a>
            <a href="/auth/login" class="btn btn-outline" style="font-size: 1.1rem; padding: 0.75rem 2rem; margin-left: 1rem;">Login</a>
        <% } else if (user) { %>
            <a href="/user/lawyers" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.75rem 2rem;">Find a Lawyer Now</a>
        <% } %>
    </div>
</div>

<div class="grid grid-cols-3" style="margin-top: 4rem;">
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">⚖️</div>
        <h3>Top Legal Experts</h3>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">We rigorously vet all registered lawyers so you can be confident you are receiving quality guidance.</p>
    </div>
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">📅</div>
        <h3>Easy Scheduling</h3>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">Skip the phone calls. Access real-time availability and book your next consultation instantly.</p>
    </div>
    <div class="card" style="text-align: center;">
        <div style="font-size: 2.5rem; margin-bottom: 1rem;">🔒</div>
        <h3>Secure & Confidential</h3>
        <p style="color: var(--text-muted); margin-top: 0.5rem;">Your bookings and case information remain strictly confidential through our encrypted system.</p>
    </div>
</div>

<%- include('layout/footer') %>
